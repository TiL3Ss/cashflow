---
// src/pages/dashboard/index.astro
import Layout from '@/layouts/Layout.astro';
import TopBar from '@/components/TopBar.astro';
import BottomNav from '@/components/BottomNav.astro';
import BudgetOverview from '@/components/BudgetOverview.astro';
import CategoryChart from '@/components/CategoryChart.astro';
import RecentExpenses from '@/components/RecentExpenses.astro';
import { ExpenseService } from '@/services/expense.service';
import { SettingsService } from '@/services/settings.service';
import { SavingsService } from '@/services/savings.service';
import PendingRecurringBanner from '@/components/PendingRecurringBanner.astro';
import { getCycleRange, formatCycleLabel } from '@/utils/dates';

const user = Astro.locals.user!;
const userId = Number(user.id);

const settings = await SettingsService.getOrDefault(userId);
const currentRange = getCycleRange(settings.incomeDay);

const [spent, savedNet, categoryTotals, recentExpenses] = await Promise.all([
  ExpenseService.getTotal(userId, currentRange),
  SavingsService.getNetMovementsInRange(userId, currentRange),
  ExpenseService.getTotalsByCategory(userId, currentRange),
  ExpenseService.list(userId, currentRange),
]);
---

<Layout title="Dashboard">
  <TopBar userName={user.name} />

  <main class="max-w-6xl mx-auto px-4 md:px-8 pb-28 md:pb-12">
    <div class="grid md:grid-cols-2 gap-5 mt-4 md:mt-2">
      <BudgetOverview
        incomeCents={settings.monthlyIncome}
        spentCents={spent}
        savedCents={savedNet}
        cycleLabel={formatCycleLabel(currentRange.from, currentRange.to)}
        configured={'configured' in settings ? settings.configured : true}
      />
      <CategoryChart data={categoryTotals} />
      <PendingRecurringBanner />
    </div>

    <div class="mt-5">
      <RecentExpenses expenses={recentExpenses} />
    </div>
  </main>

  <BottomNav />
</Layout>