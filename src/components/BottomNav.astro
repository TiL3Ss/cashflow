---
// src/components/BottomNav.astro
import { Icon } from 'astro-icon/components';
---

<nav class="md:hidden fixed bottom-4 left-4 right-4 z-50">
  <div class="card-float flex items-center justify-around px-2 py-2">
    <a href="/dashboard" class="flex flex-col items-center gap-0.5 px-4 py-2 rounded-2xl text-ink-soft hover:text-primary transition">
      <Icon name="lucide:layout-grid" class="w-5 h-5" />
      <span class="text-[10px] font-medium">Inicio</span>
    </a>
    <a href="/expenses/new" class="btn-primary w-12 h-12 rounded-full flex items-center justify-center -translate-y-3">
      <Icon name="lucide:plus" class="w-6 h-6" />
    </a>
    <a href="/expenses" class="flex flex-col items-center gap-0.5 px-4 py-2 rounded-2xl text-ink-soft hover:text-primary transition">
      <Icon name="lucide:receipt" class="w-5 h-5" />
      <span class="text-[10px] font-medium">Gastos</span>
    </a>
    <button id="logout-btn-mobile" class="flex flex-col items-center gap-0.5 px-4 py-2 rounded-2xl text-ink-soft hover:text-danger transition">
      <Icon name="lucide:log-out" class="w-5 h-5" />
      <span class="text-[10px] font-medium">Salir</span>
    </button>
  </div>
</nav>