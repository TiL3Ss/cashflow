---
// src/components/StatCard.astro
import { Icon } from 'astro-icon/components';
import { fromCents } from '@/utils/currency';

interface Props {
  totalCents: number;
  previousCents: number;
  monthLabel: string;
}
const { totalCents, previousCents, monthLabel } = Astro.props;

const diff = previousCents > 0 ? ((totalCents - previousCents) / previousCents) * 100 : 0;
const isUp = diff >= 0;
---

<div class="card-float p-8 relative overflow-hidden" data-animate="rise">
  <p class="text-sm text-ink-soft font-medium capitalize mb-1">{monthLabel}</p>
  <p class="text-xs text-ink-soft mb-4">Total gastado</p>

  <p class="money text-5xl md:text-6xl font-extrabold tracking-tight text-ink" id="total-amount" data-target={fromCents(totalCents)}>
    $0
  </p>

  {previousCents > 0 && (
    <div class={`inline-flex items-center gap-1 mt-4 px-3 py-1 rounded-full text-xs font-semibold ${isUp ? 'bg-danger/10 text-danger' : 'bg-primary/10 text-primary'}`}>
      <Icon name={isUp ? 'lucide:trending-up' : 'lucide:trending-down'} class="w-3.5 h-3.5" />
      {Math.abs(diff).toFixed(1)}% vs. mes anterior
    </div>
  )}
</div>

<script>
  function animateCount(el: HTMLElement) {
    const target = parseFloat(el.dataset.target || '0');
    const duration = 900;
    const start = performance.now();
    const formatter = new Intl.NumberFormat('es-CL', { style: 'currency', currency: 'CLP', minimumFractionDigits: 0 });

    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const value = target * eased;
      el.textContent = formatter.format(value);
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  const el = document.getElementById('total-amount');
  if (el) animateCount(el);
</script>