---
// src/components/TopBar.astro
import { Icon } from 'astro-icon/components';

interface Props {
  userName: string;
}
const { userName } = Astro.props;
---

<header class="hidden md:flex items-center justify-between px-8 py-5 max-w-6xl mx-auto">
  <a href="/dashboard" class="flex items-center gap-2">
    <div class="w-9 h-9 rounded-full bg-primary flex items-center justify-center">
      <Icon name="lucide:wallet" class="w-5 h-5 text-white" />
    </div>
    <span class="font-extrabold text-lg tracking-tight">CashFlow</span>
  </a>

  <nav class="flex items-center gap-1 card-float px-2 py-2">
    <a href="/dashboard" class="px-4 py-2 rounded-full text-sm font-medium hover:bg-bg transition flex items-center gap-2">
      <Icon name="lucide:layout-grid" class="w-4 h-4" /> Dashboard
    </a>
    <a href="/expenses" class="px-4 py-2 rounded-full text-sm font-medium hover:bg-bg transition flex items-center gap-2">
      <Icon name="lucide:receipt" class="w-4 h-4" /> Gastos
    </a>
  </nav>

  <div class="flex items-center gap-3">
    <a href="/expenses/new" class="btn-primary px-4 py-2.5 text-sm font-semibold flex items-center gap-2">
      <Icon name="lucide:plus" class="w-4 h-4" /> Nuevo gasto
    </a>
    <button id="logout-btn-desktop" class="w-10 h-10 rounded-full card-float flex items-center justify-center text-ink-soft hover:text-danger transition" title={`Cerrar sesión (${userName})`}>
      <Icon name="lucide:log-out" class="w-4 h-4" />
    </button>
  </div>
</header>

<script>
  document.querySelectorAll('#logout-btn-desktop, #logout-btn-mobile').forEach((btn) => {
    btn.addEventListener('click', async () => {
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.href = '/login';
    });
  });
</script>